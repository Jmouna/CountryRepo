pipeline {
        agent any
        tools {
            maven 'M2_HOME'
        }
        stages {
            stage('Checkout code') 
            {
                steps {
                    git branch: 'master', url: 'https://github.com/Jmouna/CountryRepo.git'
                }
            }
            stage('Build maven') 
            {
                steps {
                    sh 'mvn clean install'
                }
            }
            stage('Build Dockerfile ')
            {
                steps {
                    sh 'docker build . -t my-country-service:$BUILD_NUMBER '
                    withCredentials([string(credentialsId: 'dockerhub-paswd', variable: 'dockerhub-pwd')]){
                    sh 'docker login -u jmouna -p ${dockerhub-pwd}'
                }
                    sh 'docker tag my-country-service:$BUILD_NUMBER jmouna/my-country-service:$BUILD_NUMBER'
                    sh 'docker push jmouna/my-country-service:$BUILD_NUMBER'
            }
        }
            stage('Deploy microservice') 
            {
                 steps {
                    sh 'docker rm -f $(docker ps -aq)'
                    sh 'docker run -d -p 8082:8082 my-country-service:$BUILD_NUMBER'
                }
            }
        }
    }
